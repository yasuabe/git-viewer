{
  "name": "git-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "dev:dag": "vite --config vite.workbench-dag.config.ts",
    "dev:diff": "vite --config vite.workbench-diff.config.ts",
    "build": "tsc -b && electron-vite build",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "diff2html": "^3.4.56",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^37.2.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
